{
  "openapi": "3.0.1",
  "info": {
    "title": "🧯 Gas Project API",
    "description": "Gas Cylinder Booking & Payment Management System",
    "contact": {
      "name": "Mahendra",
      "email": "sampathimahendra@gmail.com"
    },
    "version": "1.0"
  },
  "servers": [
    {
      "url": "http://localhost:8080",
      "description": "Generated server url"
    }
  ],
  "tags": [
    {
      "name": "👤 Accounts_Section",
      "description": "🧑 [Details of Accounts] "
    },
    {
      "name": " 🔵 Cylinders_Section",
      "description": "🛢️ [Details of Cylinders] "
    },
    {
      "name": "🧾  Receipts_Section",
      "description": "📄 [Download Payments Receipts] "
    },
    {
      "name": "💳 Payments_Section",
      "description": " 💰 [Details of Payments] "
    },
    {
      "name": "📋 Booking_Section",
      "description": "📝 [Details of Bookings] "
    }
  ],
  "paths": {
    "/api/users/register": {
      "post": {
        "tags": [
          "👤 Accounts_Section"
        ],
        "summary": "[User_Register]",
        "description": "New User Register",
        "operationId": "register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "400": {
            "description": "Invalid Details"
          },
          "200": {
            "description": "User Sucessfully Registered",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Userservice"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/login": {
      "post": {
        "tags": [
          "👤 Accounts_Section"
        ],
        "summary": "[User_Login]",
        "description": "UserLogin with mobile and passwrd",
        "operationId": "login",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "User Sucessfully Logined",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Userservice"
                }
              }
            }
          },
          "400": {
            "description": "Invalid Details  to Login"
          }
        }
      }
    },
    "/api/payments": {
      "get": {
        "tags": [
          "💳 Payments_Section"
        ],
        "summary": "[Payments_History]",
        "description": "Getting Payements History ",
        "operationId": "getAllPayments",
        "responses": {
          "400": {
            "description": "No Results Found "
          },
          "200": {
            "description": "Payments History Sucessfully Showed",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": [
          "💳 Payments_Section"
        ],
        "summary": "[Payments_By_Cash]",
        "description": " Payments Accepting  By Cash Only",
        "operationId": "createPayment",
        "parameters": [
          {
            "name": "customerId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "amount",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "mode",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "CASH",
                "UPI",
                "CARD",
                "NETBANKING"
              ]
            }
          }
        ],
        "responses": {
          "400": {
            "description": "Invalid Payment Details so don't pay money"
          },
          "200": {
            "description": "Payment Sucessfully  Done By Cash Way ",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          }
        }
      }
    },
    "/api/payments/qr": {
      "post": {
        "tags": [
          "💳 Payments_Section"
        ],
        "summary": "[Payments_By_QR]",
        "description": "Make Payments  By QR Code Scanning",
        "operationId": "getPaymentQRCode",
        "parameters": [
          {
            "name": "amount",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            }
          },
          {
            "name": "customerId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "QR Code Generated Sucessfully",
            "content": {
              "image/png": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "QR Code Generation  Failed "
          }
        }
      }
    },
    "/api/cylinders": {
      "get": {
        "tags": [
          " 🔵 Cylinders_Section"
        ],
        "summary": "[Get_All_Cylinders]",
        "description": "Getting All  Cylinders",
        "operationId": "getAllCylinders",
        "responses": {
          "200": {
            "description": "Cylinders List  Showed Sucessfully ",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CylinderEntity"
                }
              }
            }
          },
          "400": {
            "description": "No  Cylinders found"
          }
        }
      },
      "post": {
        "tags": [
          " 🔵 Cylinders_Section"
        ],
        "summary": "[Add_Cylinders]",
        "description": "Adding a new Cylinder",
        "operationId": "addCylinder",
        "parameters": [
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "DOMESTIC",
                "COMMERCIAL"
              ]
            }
          },
          {
            "name": "price",
            "in": "query",
            "required": true,
            "schema": {
              "type": "number",
              "format": "double"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cylinder  Added Sucessfully ",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CylinderEntity"
                }
              }
            }
          },
          "400": {
            "description": "Invalid  Cylinder Details"
          }
        }
      }
    },
    "/api/bookings": {
      "get": {
        "tags": [
          "📋 Booking_Section"
        ],
        "summary": "[All_Bookings]",
        "description": "Getting All Bookings",
        "operationId": "getAllBookings",
        "responses": {
          "200": {
            "description": "All Bookings Sucessfully Displayed",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BookingEntity"
                }
              }
            }
          },
          "400": {
            "description": "No  Bookings Found"
          }
        }
      },
      "post": {
        "tags": [
          "📋 Booking_Section"
        ],
        "summary": "[Add_Booking]",
        "description": "Booking a Cylinder",
        "operationId": "createBooking",
        "parameters": [
          {
            "name": "customerId",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "deliveryAddress",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "type",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "DOMESTIC",
                "COMMERCIAL"
              ]
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking  Sucessfully Created",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BookingEntity"
                }
              }
            }
          },
          "400": {
            "description": "Invalid  Booking Details"
          }
        }
      }
    },
    "/api/payments/{id}/confirm": {
      "patch": {
        "tags": [
          "💳 Payments_Section"
        ],
        "summary": "[Confirm_Payment]",
        "description": "Confirming Payment  by Id ",
        "operationId": "confirmPayment",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "400": {
            "description": "Invalid Payment Id Details "
          },
          "200": {
            "description": "Payment Confirmed Sucessfully ",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          }
        }
      }
    },
    "/api/bookings/{id}/cancel": {
      "patch": {
        "tags": [
          "📋 Booking_Section"
        ],
        "summary": "[Cancel_Booking]",
        "description": "Cancelling Booking by Id",
        "operationId": "cancelBooking",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking  Sucessfully Cancelled",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BookingEntity"
                }
              }
            }
          },
          "400": {
            "description": "Invalid  Booking Id"
          }
        }
      }
    },
    "/api/receipts/{paymentId}/pdf": {
      "get": {
        "tags": [
          "🧾  Receipts_Section"
        ],
        "summary": "[Payment_Receipt_By_PDF]",
        "description": "Getting payments receipts by payment Id in PDF format",
        "operationId": "getReceiptPdf",
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "400": {
            "description": "Invalid Payment Id Details to download Payment Receipt"
          },
          "200": {
            "description": "Downloaded Payment Receipt Sucessfully ",
            "content": {
              "application/pdf": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentService"
                }
              }
            }
          }
        }
      }
    },
    "/api/receipts/{paymentId}/json": {
      "get": {
        "tags": [
          "🧾  Receipts_Section"
        ],
        "summary": "[Payment_Receipt_By_JSON]",
        "description": "Getting Payements Receipts By JSON format",
        "operationId": "getReceiptJson",
        "parameters": [
          {
            "name": "paymentId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Payment Sucessfully Displayed",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/PaymentService"
                }
              }
            }
          },
          "400": {
            "description": "Invalid Payment Id Details "
          }
        }
      }
    },
    "/api/payments/{id}/status": {
      "get": {
        "tags": [
          "💳 Payments_Section"
        ],
        "summary": "[Payments_Status]",
        "description": "Getting Payment Status by Id",
        "operationId": "getpaymentById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": " Sucessfully Showed Payment Status",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Payment"
                }
              }
            }
          },
          "400": {
            "description": "Invalid Payment Id  to View Payment Status"
          }
        }
      }
    },
    "/api/cylinders/status/{status}": {
      "get": {
        "tags": [
          " 🔵 Cylinders_Section"
        ],
        "summary": "[Cylinders_By_Status]",
        "description": "Getting Cylinders By Status",
        "operationId": "getCylinderByStatus",
        "parameters": [
          {
            "name": "status",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "AVAILABLE",
                "CONFIRMED",
                "DELIVERED",
                "PENDING",
                "CANCELLED"
              ]
            }
          }
        ],
        "responses": {
          "400": {
            "description": "Invalid  Status"
          },
          "200": {
            "description": "Cylinders  Shoed Sucessfully By Status ",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CylinderEntity"
                }
              }
            }
          }
        }
      }
    },
    "/api/bookings/{id}": {
      "get": {
        "tags": [
          "📋 Booking_Section"
        ],
        "summary": "[Booking_By_ID]",
        "description": "Get Booking by Id",
        "operationId": "getBookingById",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Booking  Sucessfully Found",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BookingEntity"
                }
              }
            }
          },
          "400": {
            "description": "Invalid  Booking ID"
          }
        }
      }
    },
    "/api/bookings/history/{customerId}": {
      "get": {
        "tags": [
          "📋 Booking_Section"
        ],
        "summary": "[Booking_History]",
        "description": "Getting Booking History",
        "operationId": "getBookingHistory",
        "parameters": [
          {
            "name": "customerId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "400": {
            "description": "Invalid Customer ID"
          },
          "200": {
            "description": "Booking History Sucessfully Dispalyed",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/BookingEntity"
                }
              }
            }
          }
        }
      }
    },
    "/api/users/{id}": {
      "delete": {
        "tags": [
          "👤 Accounts_Section"
        ],
        "summary": "[Delete_User]",
        "description": "Deleting the User",
        "operationId": "deleteUser",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "400": {
            "description": "Invalid Details  to Delete"
          },
          "200": {
            "description": "User Sucessfully Deleted",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/Userservice"
                }
              }
            }
          }
        }
      }
    },
    "/api/cylinders/{id}": {
      "delete": {
        "tags": [
          " 🔵 Cylinders_Section"
        ],
        "summary": "[Delete_Cylinder]",
        "description": "Deleting Cylinder By Id",
        "operationId": "deleteCylinder",
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Cylinder  Deleted Sucessfully ",
            "content": {
              "*/*": {
                "schema": {
                  "$ref": "#/components/schemas/CylinderEntity"
                }
              }
            }
          },
          "400": {
            "description": "Invalid  Cylinder Id"
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string"
          },
          "email": {
            "type": "string"
          },
          "password": {
            "type": "string"
          },
          "address": {
            "type": "string"
          },
          "mobileNumber": {
            "type": "string"
          }
        }
      },
      "Userservice": {
        "type": "object"
      },
      "LoginRequest": {
        "type": "object",
        "properties": {
          "mobileNumber": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "Payment": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "customerId": {
            "type": "string"
          },
          "amount": {
            "type": "number",
            "format": "double"
          },
          "payment": {
            "type": "string",
            "enum": [
              "CASH",
              "UPI",
              "CARD",
              "NETBANKING"
            ]
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "SUCCESS",
              "FAILED"
            ]
          },
          "paidDate": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "CylinderEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "type": {
            "type": "string",
            "enum": [
              "DOMESTIC",
              "COMMERCIAL"
            ]
          },
          "price": {
            "type": "number",
            "format": "double"
          },
          "status": {
            "type": "string",
            "enum": [
              "AVAILABLE",
              "CONFIRMED",
              "DELIVERED",
              "PENDING",
              "CANCELLED"
            ]
          }
        }
      },
      "BookingEntity": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64",
            "readOnly": true
          },
          "cylinderType": {
            "type": "string"
          },
          "customerId": {
            "type": "string"
          },
          "bookingDate": {
            "type": "string",
            "format": "date"
          },
          "deliveryAddress": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "PENDING",
              "CONFIRMED",
              "CANCELLED",
              "DELIVERED"
            ]
          }
        }
      },
      "PaymentService": {
        "type": "object",
        "properties": {
          "allPayments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/Payment"
            }
          }
        }
      }
    }
  }
}